# ─────────────────────────────────────────────────────────────────────────────
# ERP Ecopremium — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus dados reais.
# NUNCA commite o arquivo .env no Git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
# Chave secreta do Django (gere uma nova em produção)
SECRET_KEY=django-insecure-troque-esta-chave-em-producao-123456

# Em produção, use False
DEBUG=False

# ── Supabase — Banco de Dados (PostgreSQL) ────────────────────────────────────
# Encontre em: Supabase Dashboard → Project Settings → Database → Connection String
# Use a URI com "Transaction pooler" (porta 6543) para Vercel (serverless)
DATABASE_URL=postgresql://postgres.[SEU-PROJETO]:[SUA-SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres

# ── Supabase — API Keys ───────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Project Settings → API

# URL do seu projeto Supabase (ex: https://xyzabcdef.supabase.co)
SUPABASE_URL=https://[SEU-PROJETO].supabase.co

# Chave pública (anon) — segura para usar no frontend
SUPABASE_ANON_KEY=eyJ...

# Chave de serviço (service_role) — NUNCA exponha no frontend!
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Chave publicável (se utilizar Supabase Auth no frontend)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURAÇÃO NO VERCEL
# ─────────────────────────────────────────────────────────────────────────────
# No painel do Vercel, vá em:
#   Project → Settings → Environment Variables
# E adicione as seguintes variáveis:
#
#   DATABASE_URL        → sua connection string do Supabase
#   SECRET_KEY          → uma chave secreta forte
#   DEBUG               → False
#   SUPABASE_URL        → URL do projeto
#   SUPABASE_ANON_KEY   → chave anon pública
#   SUPABASE_SERVICE_ROLE_KEY → chave de serviço (opcional)
# ─────────────────────────────────────────────────────────────────────────────
