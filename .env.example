# ── Django ────────────────────────────────────────────────────────────────────
# Chave secreta do Django (gere uma nova em produção)
SECRET_KEY=django-insecure-troque-esta-chave-em-producao-123456

# Em produção, use False
DEBUG=True

# ── Supabase — Banco de Dados (PostgreSQL) ────────────────────────────────────
# Encontre em: Supabase Dashboard → Project Settings → Database → Connection String
# Use a URI com "Transaction pooler" (porta 6543) para Vercel (serverless)
DATABASE_URL=postgresql://postgres.coetaopmgkbpjarflqgn:ni39514645ni@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# ── Supabase — API Keys ───────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard → Project Settings → API

# URL do seu projeto Supabase (ex: https://xyzabcdef.supabase.co)
SUPABASE_URL=https://coetaopmgkbpjarflqgn.supabase.co

